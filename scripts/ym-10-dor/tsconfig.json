{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "src",
    "types": ["node", "electron"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/renderer/**"]
}
